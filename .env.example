# Backend Node.js Server
BACKEND_PORT=3001
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=ai_recruiter_db

# Frontend
FRONTEND_PORT=5173
FRONTEND_LOGIN_PORT=5174

# Interview Scheduling Service (Python/FastAPI)
SCHEDULING_SERVICE_PORT=5004
SCHEDULING_SERVICE_HOST=0.0.0.0

# Google Calendar OAuth (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5004/auth/google/callback
GOOGLE_CALENDAR_ID=primary

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@ai-recruiter.com
EMAIL_FROM_NAME=AI Recruiter Platform

# SendGrid Alternative
SENDGRID_API_KEY=

# Interview Configuration
INTERVIEW_DURATION_DEFAULT=60
WORKING_HOURS_START=09
WORKING_HOURS_END=17
LUNCH_START=12
LUNCH_END=13
SCHEDULING_DAYS_AHEAD=7
TIMEZONE_DEFAULT=UTC

# Python AI Services
FLASK_AI_PORT=5000
FLASK_QUIZ_PORT=5003

# YOLOv8 Vision Service (Object Detection)
YOLO_ENABLED=true
YOLO_SERVICE_URL=http://localhost:8001/detect-frame
YOLO_FRAME_INTERVAL_MS=1500
YOLO_TIMEOUT_MS=3000
YOLO_CONFIDENCE=0.25
YOLO_PHONE_CONFIDENCE=0.55
YOLO_BOOK_CONFIDENCE=0.55
YOLO_SCREEN_CONFIDENCE=0.60

# logging/Debug
DEBUG=false
LOG_LEVEL=INFO
