# ─────────────────────────────────────────────────────────────────────────────
# Speech Stack – runtime environment variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Whisper (STT) ─────────────────────────────────────────────────────────────
FW_MODEL=distil-large-v3
FW_DEVICE=cuda
FW_COMPUTE_TYPE=int8_float16
# Language: "en" | "fr" | "auto" (auto = slower, multilingual)
FW_LANGUAGE=en
FW_BEAM_SIZE=1

# ── Transcript correction ──────────────────────────────────────────────────────
FW_ENABLE_TRANSCRIPT_CORRECTION=1
FW_CORRECTION_CONFIDENCE_THRESHOLD=0.98

# ── Sentiment ─────────────────────────────────────────────────────────────────
FW_NEUTRAL_THRESHOLD=0.65

# ── TTS Provider: "elevenlabs" | "xtts_v2" ───────────────────────────────────
FW_TTS_PROVIDER=elevenlabs

# ── ElevenLabs TTS (recommended – cloud, no GPU needed) ──────────────────────
# Get your free key at: https://elevenlabs.io  → Profile → API Keys
ELEVENLABS_API_KEY=sk_YOUR_KEY_HERE
# Voice ID (default = "Rachel" – clear neutral English, free tier)
# Find more voice IDs at: https://api.elevenlabs.io/v1/voices (with your key)
# or in your ElevenLabs dashboard → Voices → Copy ID
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Model: eleven_flash_v2_5 (fast) | eleven_multilingual_v2 (higher quality)
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# Voice style (0.0–1.0)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# ── XTTS-v2 (local, needs GPU + Coqui TTS installed) ─────────────────────────
# FW_TTS_PROVIDER=xtts_v2
# FW_TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
# FW_TTS_SPEAKER_WAV=         # path to a reference speaker WAV file
# FW_TTS_SPEAKER_DIR=         # directory of speaker WAV files
# FW_TTS_LANGUAGE=en
# FW_TTS_USE_GPU=auto
# FW_TTS_SPEED=1.12
# FW_PRELOAD_TTS=1
