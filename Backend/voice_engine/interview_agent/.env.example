# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider: "nvidia" | "ollama" | "anthropic" | "openai" | "echo"
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=nvidia

# ── NVIDIA NIM (free cloud API — RECOMMENDED) ─────────────────────────────────
# 1. Sign up at https://build.nvidia.com
# 2. Click your profile → "Generate API Key"  (key starts with "nvapi-")
# 3. Paste it below.  Free tier: ~40 req/min, no expiry.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Good free models for interview tasks (strong JSON + instruction following):
#   meta/llama-3.3-70b-instruct          ← default, best quality
#   meta/llama-3.1-8b-instruct           ← faster / lighter
#   mistralai/mistral-7b-instruct-v0.3   ← alternative
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b-instruct

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI-compatible gateway ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Service ───────────────────────────────────────────────────────────────────
AGENT_PORT=8013

# ── Context / memory tuning (optional) ────────────────────────────────────────
# Number of recent transcript turns included in the LLM prompt tail.
# Range 4–20; default 8. Higher → better duplicate-question detection.
# AGENT_TRANSCRIPT_TAIL_TURNS=12

# Number of turns in the short-term memory window sent to the LLM.
# Range 3–16; default 6. Higher → agent remembers more of the conversation.
# AGENT_SHORT_TERM_MEMORY_TURNS=8
