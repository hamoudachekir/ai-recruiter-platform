# Copy to Backend/server/AI/.env and set your real key

# Enable/disable Mistral generation
QUIZ_USE_MISTRAL=true

# Mistral API key
MISTRAL_API_KEY=your_mistral_api_key_here

# Model id (Ministral 8B Instruct)
MISTRAL_MODEL=ministral-8b-latest

# API endpoint and timeout
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_TIMEOUT=30
