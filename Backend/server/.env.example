# LinkedIn Apify enrichment
APIFY_TOKEN=
APIFY_ACTOR_ID=

# Google Calendar OAuth (must match an Authorized redirect URI in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Optional: keep LinkedIn OAuth disabled for manual/apify mode
LINKEDIN_MANUAL_ONLY=true

# AI Interview Integrity Assistant
# disabled = MediaPipe + deterministic scoring only
# openai/gemini = analyze flagged snapshots and optionally generate report text
VISION_LLM_PROVIDER=gemini
VISION_LLM_MODEL=gemini-2.5-flash-lite
INTEGRITY_REPORT_LLM_PROVIDER=disabled
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
VISION_OPENAI_MODEL=gpt-4o-mini
INTEGRITY_OPENAI_MODEL=gpt-4o-mini
INTEGRITY_GEMINI_MODEL=gemini-1.5-flash

# YOLOv8 Vision Service (Object Detection)
# Set YOLO_ENABLED=false to disable object detection
YOLO_ENABLED=true
YOLO_SERVICE_URL=http://localhost:8001/detect-frame
YOLO_TIMEOUT_MS=3000
YOLO_CONFIDENCE=0.25
YOLO_PHONE_CONFIDENCE=0.55
YOLO_BOOK_CONFIDENCE=0.55
YOLO_SCREEN_CONFIDENCE=0.60
