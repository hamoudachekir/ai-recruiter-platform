# LinkedIn Apify enrichment
APIFY_TOKEN=
APIFY_ACTOR_ID=

# Google Calendar OAuth (must match an Authorized redirect URI in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Optional: keep LinkedIn OAuth disabled for manual/apify mode
LINKEDIN_MANUAL_ONLY=true
