# Interview Scheduling Service Configuration

# Service
SERVICE_NAME=interview-scheduling
SERVICE_PORT=5004
SERVICE_HOST=0.0.0.0
DEBUG=False

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=ai_recruiter_db

# Node.js Backend (for fetching candidate/recruiter/job data)
NODE_BACKEND_URL=http://localhost:3001
NODE_INTERNAL_SCHEDULING_PATH=/api/internal/scheduling
NODE_INTERNAL_API_KEY=your-internal-api-key
NODE_HTTP_TIMEOUT_SECONDS=10

# Google Calendar OAuth (Phase 2)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5004/auth/google/callback
GOOGLE_CALENDAR_ID=primary
# Optional local fallback token if Node internal endpoint is unavailable
GOOGLE_ACCESS_TOKEN_FALLBACK=

# Email Configuration - SMTP Option
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
EMAIL_FROM=noreply@ai-recruiter.com
EMAIL_FROM_NAME=AI Recruiter Platform
EMAIL_PROVIDER=auto
FRONTEND_CONFIRMATION_URL=http://localhost:5173

# Email Configuration - SendGrid Option (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@ai-recruiter.com

# Interview Configuration
INTERVIEW_DURATION_DEFAULT=60
WORKING_HOURS_START=09
WORKING_HOURS_END=17
LUNCH_START=12
LUNCH_END=13
SCHEDULING_DAYS_AHEAD=7
TIMEZONE_DEFAULT=UTC

# Logging
LOG_LEVEL=INFO

# Side-effect retry queue (calendar/email)
SIDE_EFFECT_RETRY_ENABLED=True
SIDE_EFFECT_RETRY_POLL_SECONDS=30
SIDE_EFFECT_RETRY_MAX_ATTEMPTS=5
SIDE_EFFECT_RETRY_BACKOFF_SECONDS=60
SIDE_EFFECT_RETRY_BATCH_SIZE=10

# Security
API_KEY=your-internal-api-key-for-inter-service-calls
JWT_SECRET=your-jwt-secret-from-node-backend
